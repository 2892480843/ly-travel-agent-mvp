# Leave empty (recommended): the browser calls same-origin /api and the Vite
# dev server proxies it to the backend below. Only set an absolute URL when
# the API is deployed on a different public domain.
VITE_API_BASE_URL=

# Data mode: "demo" (dev/showcase, silent local fallbacks) or "live"
# (real deployment: demo content is labelled, service outages show a banner).
# Empty = auto: dev server -> demo, production build -> live.
VITE_DATA_MODE=

# Client-side public switches. Do not put real secrets in VITE_* variables.
VITE_MAP_PROVIDER=fallback
VITE_AMAP_JS_KEY=
VITE_AMAP_SECURITY_JS_CODE=
VITE_AMAP_SERVICE_HOST=
VITE_WEATHER_API_BASE_URL=
VITE_TICKET_API_BASE_URL=
VITE_PAYMENT_PROVIDER=sandbox

# Server
PORT=8787
DATABASE_URL=file:./data/ly.sqlite
AUTH_COOKIE_NAME=ly_session
AUTH_SESSION_SECRET=change-me-in-real-deployments

# Server-side AI adapter for /api/agent/chat.
# Leave AI_PROVIDER=fallback when no model key is available.
AI_PROVIDER=fallback
AI_BASE_URL=
AI_API_KEY=
AI_MODEL=demo-local

PAYMENT_PROVIDER=sandbox
PAYMENT_API_BASE_URL=
PAYMENT_API_KEY=
PAYMENT_WEBHOOK_SECRET=

# Server-side map provider. Use MAP_PROVIDER=amap with a Web Service key.
MAP_PROVIDER=amap
MAP_API_KEY=
TICKET_PROVIDER=sandbox
TICKET_API_BASE_URL=
TICKET_API_TOKEN=
TICKET_API_SECRET=

AI_TIMEOUT_MS=20000

AI_MAX_TOKENS=700
