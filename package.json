{
  "scripts": {
    "dev": "vite",
    "dev:client": "vite",
    "dev:server": "npm run build:server && node server-dist/server/index.js",
    "db:init": "npm run build:server && node server-dist/server/scripts/init-db.js",
    "db:seed": "npm run build:server && node server-dist/server/scripts/seed-db.js",
    "smoke:api": "node scripts/api-smoke.mjs",
    "readiness": "node scripts/readiness-check.mjs",
    "readiness:prod": "node scripts/readiness-check.mjs --production",
    "secret:generate": "node scripts/generate-secret.mjs",
    "build": "tsc -b && vite build",
    "build:server": "tsc -p tsconfig.server.json",
    "build:all": "npm run build:server && npm run build",
    "start": "node server-dist/server/index.js",
    "deploy": "npm ci && npm run build:all && npm run readiness && npx pm2 startOrReload ecosystem.config.cjs && npx pm2 save",
    "deploy:prod": "npm ci && npm run build:all && npm run readiness:prod && npx pm2 startOrReload ecosystem.config.cjs --env production && npx pm2 save",
    "test": "vitest run",
    "preview": "vite preview"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.35",
    "@ai-sdk/react": "^3.0.201",
    "@vitejs/plugin-react": "^5.0.0",
    "ai": "^6.0.199",
    "framer-motion": "^12.23.0",
    "lucide-react": "^0.541.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.8.0",
    "recharts": "^3.1.2",
    "remark-gfm": "^4.0.1",
    "typescript": "^5.9.0",
    "vite": "^7.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.1.8"
  }
}
